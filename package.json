{
  "name": "apploljey.gg",
  "version": "1.0.0",
  "description": "App de runas para LoL",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Jey",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "league-connect": "^6.0.0-rc13",
    "puppeteer": "^25.2.1"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.jeygg.app",
    "productName": "JeyggRunes",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!dist/*",
      "!build/*"
    ]
  }
}